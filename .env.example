ANTHROPIC_API_KEY=your_anthropic_api_key_here
PORT=3000
DEFAULT_MODEL=claude-sonnet-4-6

# Optional proxy protection. Clients send: Authorization: Bearer <value>
PROXY_API_KEY=change-me

# Comma-separated browser origins. Empty allows all origins for local development.
ALLOWED_ORIGINS=http://localhost:3000
BODY_LIMIT=10mb

# Used only by cli-proxy.js. Its default port is 3001.
CLAUDE_BIN=/Users/your-name/.local/bin/claude

# Kills the CLI process if it hasn't finished within this many milliseconds.
CLI_TIMEOUT_MS=120000
